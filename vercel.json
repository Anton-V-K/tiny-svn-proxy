{
  "version": 2,
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  },
  "routes": [
    { "handle": "filesystem" },
    {
      "src": "^/api/(.+)$",
      "methods": [
        "GET",
        "HEAD",
        "POST",
        "PUT",
        "PATCH",
        "DELETE",
        "OPTIONS"
      ],
      "dest": "/api/proxy?path=$1"
    },
    {
      "src": "^/api/(.+)$",
      "methods": [
        "PROPFIND",
        "PROPPATCH",
        "MKACTIVITY",
        "CHECKOUT",
        "MERGE",
        "REPORT",
        "MKCOL",
        "COPY",
        "MOVE",
        "LOCK"
      ],
      "dest": "/api/proxy?path=$1"
    },
    {
      "src": "^/api/(.+)$",
      "methods": ["UNLOCK"],
      "dest": "/api/proxy?path=$1"
    }
  ],
  "rewrites": [{ "source": "/", "destination": "/api" }]
}
